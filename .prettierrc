{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "printWidth": 120,
  "tabWidth": 2,
  "endOfLine": "lf",
  "proseWrap": "preserve",
  "singleAttributePerLine": true,
  "htmlWhitespaceSensitivity": "css",
  "embeddedLanguageFormatting": "auto",
  "overrides": [
    {
      "files": ["*.md"],
      "options": {
        "proseWrap": "preserve",
        "tableFormat": "preserve",
        "tabWidth": 1,
        "markdownTablePrettify": false  
      }
    }
  ]
}